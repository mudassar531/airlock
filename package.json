{
  "name": "airlock",
  "version": "0.1.0",
  "description": "A firewall and flight recorder for AI agents — least-privilege approval and a tamper-evident audit log for every action your agent takes.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "airlock": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "policy.example.yaml",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:unsafe": "npm run build && node dist/demo/attack-scenario.js unsafe",
    "demo:safe": "npm run build && node dist/demo/attack-scenario.js safe",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "node-notifier": "^10.0.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/node-notifier": "^8.0.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "ai-safety",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "prompt-injection",
    "security",
    "audit-log",
    "firewall",
    "approval",
    "least-privilege",
    "agent-safety"
  ]
}
